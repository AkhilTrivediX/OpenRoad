{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "server-dist",
    "noEmit": false
  },
  "include": ["server/**/*.ts", "src/domain/**/*.ts", "src/integrations/**/*.ts"],
  "exclude": ["server/**/*.test.ts", "src/**/*.test.ts"]
}
